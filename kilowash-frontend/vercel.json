{
  "redirects": [
    {
      "source": "/",
      "destination": "/src/pages/login.html",
      "permanent": false
    }
  ],
  "rewrites": [
    {
      "source": "/src/pages/:page",
      "destination": "/src/pages/:page"
    }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "X-Frame-Options", "value": "SAMEORIGIN" }
      ]
    }
  ]
}
